@startuml OVES WorkBuddy Architecture

' ===== STYLING =====
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam roundcorner 25
skinparam defaultTextAlignment center
skinparam WrapWidth 1400

' ===== LOCAL DESKTOP (PRIVATE) =====
rectangle "WorkBuddy\nAgentic Gateway" as WB <<$archimate/business-process>> #Business

rectangle "Built-in WB Skills\n(context injection)" as WBSkills <<$archimate/application-component>> #Application
rectangle "OpenClaw\nAgentic Automations" as OpenClaw <<$archimate/application-component>> #Application

rectangle "MCPs & Connectors\n(local process)" as MCPLayer <<$archimate/application-service>> #Application

' ===== AUTH LAYER =====
rectangle "MS Teams / Azure AD\n(per-user SSO & access control)" as AzureAD <<$archimate/technology-device>> #Motivation

' ===== DATA SOURCES =====
rectangle "MS Azure\nTeams / OneDrive / SharePoint" as Azure <<$archimate/technology-device>> #Technology
rectangle "Odoo\nCRM / MRP / Finance" as Odoo <<$archimate/technology-device>> #Technology
rectangle "docs.omnivoltaic.com\nGlobal Document Portal" as Docs <<$archimate/technology-device>> #Technology
rectangle "GitHub\nCode Repos + Shared Skills/Config" as GitHub <<$archimate/technology-device>> #Technology
rectangle "Cloudinary\nMedia Depot & Services" as Cloudinary <<$archimate/technology-device>> #Technology

' ===== INFRASTRUCTURE =====
rectangle "AWS\nCloud Compute / PVC / K8s" as AWS <<$archimate/technology-device>> #Technology
rectangle "Cloudflare\nCDN" as CF <<$archimate/technology-device>> #Technology

' ===== GROUPINGS =====
rectangle "Local Desktop (Private)" as LocalGroup #Application
rectangle "Data Sources & Systems" as DataGroup #Technology
rectangle "Infrastructure" as InfraGroup #Technology

' ===== RELATIONSHIPS =====
WB -right-> WBSkills
WB -right-> OpenClaw
WB -down-> MCPLayer

' Auth
MCPLayer ..> AzureAD : authenticates via\n(not managed by WB)

' MCP → Data Sources
MCPLayer -down-> Azure
MCPLayer -down-> Odoo
MCPLayer -down-> Docs
MCPLayer -down-> GitHub
MCPLayer -down-> Cloudinary

' Skills shared via GitHub
WBSkills ..> GitHub : shared via\nskills repo

' Data → Infrastructure
Docs -down-> AWS
Docs -down-> CF
GitHub -down-> CF

' ===== ANNOTATIONS =====
note right of WB
  **Pure local desktop app**
  Does NOT manage access control.
  Each user brings their own
  Azure AD credentials.
  Skills shared via GitHub.
end note

note right of AzureAD
  **SSO boundary**
  Each user authenticates
  individually. WB passes
  existing credentials;
  never stores them.
end note

note right of GitHub
  **Shared config hub**
  Skills, MCP templates,
  and configs persisted
  in workbuddy-config repo.
end note

footer Omnivoltaic WorkBuddy | %filename() rendered with PlantUML version %version()

@enduml
