@startuml WorkBuddy Extension Architecture (ArchiMate)

' ===== STYLING =====
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam roundcorner 25
skinparam defaultTextAlignment center

' ===== BUSINESS LAYER =====
rectangle "LLM + Agent Loop" as LLM <<$archimate/business-process>> #Business

' ===== APPLICATION LAYER =====
rectangle "Skill (SKILL.md)\ncontext injection" as SkillMd <<$archimate/application-component>> #Application
rectangle "MCP Server\nstdio / HTTP" as McpServer <<$archimate/application-service>> #Application
rectangle "Connector\npackaged MCP + auth" as Connector <<$archimate/application-service>> #Application

' ===== TECHNOLOGY LAYER =====
rectangle "GitHub\nREST + GraphQL" as GitHub <<$archimate/technology-device>> #Technology
rectangle "Notion\nREST API" as Notion <<$archimate/technology-device>> #Technology
rectangle "Odoo\nXML-RPC" as Odoo <<$archimate/technology-device>> #Technology
rectangle "Cloudflare\nREST API" as CF <<$archimate/technology-device>> #Technology

' ===== LAYER GROUPINGS =====
rectangle "Skills" as SkillsGroup #Application
rectangle "MCP & Connectors" as MCPGroup #Application
rectangle "External APIs" as APIsGroup #Technology

SkillMd -[hidden]right-> McpServer
McpServer -[hidden]right-> Connector

' ===== STRUCTURAL RELATIONSHIPS =====
LLM -down-> SkillMd : triggers\n(loads into context)
LLM -down-> McpServer : triggers\n(JSON-RPC 2.0)
LLM -down-> Connector : triggers\n(managed auth)

SkillMd -[hidden]down-> MCPGroup

McpServer -down-> GitHub : calls
McpServer -down-> Notion : calls
McpServer -down-> Odoo : calls
McpServer -down-> CF : calls

Connector -down-> GitHub : calls via\npackaged auth
Connector -down-> Notion : calls via\npackaged auth
Connector -down-> Odoo : calls via\npackaged auth
Connector -down-> CF : calls via\npackaged auth

' ===== ANNOTATIONS =====
note right of SkillMd
  **Application Component**
  Markdown instructions loaded
  into LLM context window.
  No code execution.
  Stored at ~/.workbuddy/skills/
end note

note right of McpServer
  **Application Service**
  Model Context Protocol
  (like LSP for IDEs).
  JSON-RPC 2.0 transport.
  Any language.
end note

note right of Connector
  **Application Service**
  Pre-packaged MCP server
  with OAuth2 flow +
  credential refresh.
  Managed by WorkBuddy host.
end note

footer Omnivoltaic WorkBuddy | %filename() rendered with PlantUML version %version()

@enduml
