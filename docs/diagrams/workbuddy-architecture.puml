@startuml OVES WorkBuddy Architecture

' ===== STYLING =====
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam roundcorner 25
skinparam defaultTextAlignment center

' ===== LAYER: AGENTIC GATEWAY =====
rectangle "WorkBuddy\nAgentic Gateway" as WB <<$archimate/business-process>> #Business

' ===== LAYER: MCPs & CONNECTORS =====
rectangle "Azure MCP\nTeams / OneDrive / SharePoint" as AzureMCP <<$archimate/application-service>> #Application
rectangle "Odoo MCP\nCRM / MRP / Finance" as OdooMCP <<$archimate/application-service>> #Application
rectangle "Docs MCP\nportal connector" as DocsMCP <<$archimate/application-service>> #Application
rectangle "GitHub MCP\ncodebase connector" as GitHubMCP <<$archimate/application-service>> #Application
rectangle "Cloudinary MCP\nmedia depot connector" as CloudinaryMCP <<$archimate/application-service>> #Application

' ===== LAYER: DATA SOURCES =====
rectangle "MS Azure\nTeams / OneDrive / SharePoint" as Azure <<$archimate/technology-device>> #Technology
rectangle "Odoo\nCRM / MRP / Finance" as Odoo <<$archimate/technology-device>> #Technology
rectangle "docs.omnivoltaic.com\nGlobal Document Portal" as Docs <<$archimate/technology-device>> #Technology
rectangle "GitHub\nAll Codebase Repos" as GitHub <<$archimate/technology-device>> #Technology
rectangle "Cloudinary\nMedia Depot & Services" as Cloudinary <<$archimate/technology-device>> #Technology

' ===== LAYER: INFRASTRUCTURE =====
rectangle "AWS\nCloud Compute / PVC / K8s" as AWS <<$archimate/technology-device>> #Technology
rectangle "Cloudflare\nCDN" as CF <<$archimate/technology-device>> #Technology

' ===== GROUPINGS =====
rectangle "MCPs & Connectors" as MCPGroup #Application
rectangle "Data Sources & Systems" as DataGroup #Technology
rectangle "Infrastructure" as InfraGroup #Technology

' ===== RELATIONSHIPS: WB → MCPs =====
WB -down-> AzureMCP
WB -down-> OdooMCP
WB -down-> DocsMCP
WB -down-> GitHubMCP
WB -down-> CloudinaryMCP

' ===== RELATIONSHIPS: MCPs → Data Sources =====
AzureMCP -down-> Azure
OdooMCP -down-> Odoo
DocsMCP -down-> Docs
GitHubMCP -down-> GitHub
CloudinaryMCP -down-> Cloudinary

' ===== RELATIONSHIPS: Data Sources → Infrastructure =====
Docs -down-> AWS
Docs -down-> CF
GitHub -down-> CF

' ===== ANNOTATIONS =====
note right of WB
  **Agentic Gateway**
  Single coordination point
  for all MCPs and skills.
  Manages connector lifecycle.
end note

note right of MCPGroup
  Each MCP exposes tools
  via Model Context Protocol.
  Skills define workflows
  combining multiple MCPs.
end note

footer Omnivoltaic WorkBuddy | %filename() rendered with PlantUML version %version()

@enduml
