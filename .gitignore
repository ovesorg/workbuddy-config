# Credentials — never commit real tokens/keys/passwords
*.template
*credentials*.json
*secrets*.json
*_config.json
*_secret*
*.key
.env

# Local overrides (team members fill in their own)
mcp.local.json
connectors/*/mcp.local.json
models.json

# MkDocs build output
site/

# MkDocs date cache (build artifact)
docs/.dates_cache.jsonl
docs/.gitattributes

# OS junk
.DS_Store
Thumbs.db

# WorkBuddy local state (never share)
workbuddy.db
workbuddy.db-shm
workbuddy.db-wal
*.lockfile
user-state.json
workspace-state.json

# Python bytecode
__pycache__/
*.pyc
*.pyo

# App internals
app/
traces/
BINARIES/
binaries/
session/
