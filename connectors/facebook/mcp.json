{
  "mcpServers": {
    "facebook": {
      "command": "python",
      "args": ["-m", "facebook_mcp_server"],
      "timeout": 600,
      "env": {
        "FACEBOOK_ACCESS_TOKEN": "${FACEBOOK_ACCESS_TOKEN}",
        "FACEBOOK_PAGE_ID": "${FACEBOOK_PAGE_ID}"
      },
      "disabled": false
    }
  }
}
