{
    "mcpServers": {
        "odoo": {
            "timeout": 600,
            "command": "npx",
            "args": ["-y", "@odoo/mcp@latest"],
            "env": {
                "ODOO_URL": "${ODOO_URL}",
                "ODOO_DB": "${ODOO_DB}",
                "ODOO_USERNAME": "${ODOO_USERNAME}",
                "ODOO_API_KEY": "${ODOO_API_KEY}"
            }
        }
    }
}
